#!/bin/bash
# agent-keepalive ‚Äî Background watcher that kicks the manager when agents need attention.
# Usage: agent-keepalive [--interval SECONDS] [--cooldown SECONDS]
#
# Polls agent state. When there's pending/idle work or cluster jobs running,
# kicks the registered manager window (not the workers ‚Äî the manager has context
# to decide what to assign where).

BIN="$(cd "$(dirname "$0")" && pwd)"
INTERVAL=45          # poll interval (seconds)
COOLDOWN=300         # min seconds between kicks
STATE_FILE="$HOME/.claude/agent-tasks.json"
LOG_FILE="$HOME/.claude/keepalive.log"
LAST_KICK=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --interval) INTERVAL="$2"; shift 2 ;;
    --cooldown) COOLDOWN="$2"; shift 2 ;;
    *) shift ;;
  esac
done

log() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') $*" >> "$LOG_FILE"
}

log "keepalive started (interval=${INTERVAL}s cooldown=${COOLDOWN}s)"

while true; do
  sleep "$INTERVAL"

  # Read state file
  [[ -f "$STATE_FILE" ]] || continue
  tasks=$(cat "$STATE_FILE" 2>/dev/null) || continue

  # Get manager window
  manager_win=$(echo "$tasks" | python3 -c "
import json, sys
state = json.load(sys.stdin)
m = state.get('manager', state.get('manager_win', ''))
# resolve kitty_win from agent registry if manager is registered
if m and state.get('agents'):
    agent = next((a for a in state['agents'] if a.get('id') == m), None)
    if agent and agent.get('kitty_win'):
        m = agent['kitty_win']
print(m)
" 2>/dev/null)

  [[ -z "$manager_win" ]] && continue

  # Cooldown check
  now_epoch=$(date +%s)
  elapsed=$((now_epoch - LAST_KICK))
  [[ $elapsed -lt $COOLDOWN ]] && continue

  # Check what needs attention
  summary=$(echo "$tasks" | python3 -c "
import json, sys
state = json.load(sys.stdin)
tasks = state.get('tasks', [])
pending = sum(1 for t in tasks if t['status'] == 'pending')
idle = sum(1 for t in tasks if t['status'] == 'idle')
blocked = sum(1 for t in tasks if t['status'] == 'blocked')
parts = []
if idle > 0: parts.append(f'{idle} idle agent(s) awaiting review')
if pending > 0: parts.append(f'{pending} pending task(s)')
if blocked > 0: parts.append(f'{blocked} blocked task(s)')
print('|'.join(parts))
" 2>/dev/null)

  # Build reason string
  reason="$summary"

  [[ -z "$reason" ]] && continue

  # Check if manager is idle
  output=$("$BIN/agent-read" "$manager_win" 2>/dev/null) || continue
  [[ -z "$output" ]] && continue

  if echo "$output" | grep -q "esc to interrupt"; then
    continue  # manager is working
  fi

  last_line=$(echo "$output" | grep -v '^[[:space:]‚îÄ‚îÅ‚ïê-]*$' | grep -v '^\s*\(\?\|esc \|[0-9]* bash\|‚¨á\|Context left\|Tip:\)' | tail -1)
  if ! echo "$last_line" | grep -qE '^[‚ùØ>][[:space:]]*$'; then
    continue  # not idle
  fi

  # Format and send
  msg="Kick: $(echo "$reason" | tr '|' '. '). Run task_list() and check on your agents ‚Äî read their output, see if they've flagged issues or questions. Don't just wait, look at what they're telling you. ‚Äî keepalive watcher"

  "$BIN/agent-ask" "$manager_win" "$msg" >/dev/null 2>&1
  LAST_KICK=$now_epoch
  log "kicked manager (win $manager_win): $msg"
done
