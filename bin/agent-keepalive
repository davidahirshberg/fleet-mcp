#!/bin/bash
# agent-keepalive — Background watcher that kicks the manager when agents need attention.
# Usage: agent-keepalive [--interval SECONDS] [--cooldown SECONDS]
#
# Polls agent state. When there's pending/idle work or cluster jobs running,
# kicks the registered manager window (not the workers — the manager has context
# to decide what to assign where).

BIN="$(cd "$(dirname "$0")" && pwd)"
INTERVAL=45          # poll interval (seconds)
COOLDOWN=300         # base min seconds between kicks
MAX_COOLDOWN=3600    # max cooldown after repeated identical kicks (1 hour)
STATE_FILE="$HOME/.claude/agent-tasks.json"
LOG_FILE="$HOME/.claude/keepalive.log"
LAST_KICK=0
LAST_SUMMARY=""
REPEAT_COUNT=0
CURRENT_COOLDOWN=$COOLDOWN

while [[ $# -gt 0 ]]; do
  case "$1" in
    --interval) INTERVAL="$2"; shift 2 ;;
    --cooldown) COOLDOWN="$2"; shift 2 ;;
    *) shift ;;
  esac
done

log() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') $*" >> "$LOG_FILE"
}

log "keepalive started (interval=${INTERVAL}s cooldown=${COOLDOWN}s)"

while true; do
  sleep "$INTERVAL"

  # Read state file
  [[ -f "$STATE_FILE" ]] || continue

  # Get all manager windows
  manager_wins=$(python3 -c "
import json, sys
state = json.load(open('$STATE_FILE'))
agents = state.get('agents', [])
wins = []
for a in agents:
    if a.get('is_manager') and a.get('kitty_win'):
        wins.append(str(a['kitty_win']))
print(' '.join(wins))
" 2>/dev/null)

  [[ -z "$manager_wins" ]] && continue

  # Cooldown check (with backoff for repeated identical state)
  now_epoch=$(date +%s)
  elapsed=$((now_epoch - LAST_KICK))
  [[ $elapsed -lt $CURRENT_COOLDOWN ]] && continue

  # Check what needs attention (skip tasks for dead agents)
  summary=$(python3 -c "
import json, sys, subprocess
state = json.load(open('$STATE_FILE'))
tasks = state.get('tasks', [])
agents = {a.get('id'): a for a in state.get('agents', [])}
from datetime import datetime, timedelta
ALIVE_THRESHOLD = timedelta(minutes=10)
def agent_alive(t):
    a = agents.get(t.get('agent'))
    if not a: return False
    # Heartbeat check: last_seen within threshold
    ls = a.get('last_seen')
    if ls:
        try:
            seen = datetime.fromisoformat(ls.replace('Z', '+00:00'))
            if (datetime.now(seen.tzinfo) - seen) < ALIVE_THRESHOLD: return True
        except: pass
    # Fall back to kitty window check
    if a.get('kitty_win'):
        try:
            subprocess.run(['$BIN/agent-exists', str(a['kitty_win'])], timeout=5, capture_output=True, check=True)
            return True
        except: pass
    return False
live = [t for t in tasks if agent_alive(t) and not t.get('synthetic')]
pending = sum(1 for t in live if t['status'] == 'pending')
idle = sum(1 for t in live if t['status'] == 'idle')
blocked = sum(1 for t in live if t['status'] == 'blocked')
parts = []
if idle > 0: parts.append(f'{idle} idle agent(s) awaiting review')
if pending > 0: parts.append(f'{pending} pending task(s)')
if blocked > 0: parts.append(f'{blocked} blocked task(s)')
print('|'.join(parts))
" 2>/dev/null)

  # Build reason string
  reason="$summary"

  [[ -z "$reason" ]] && continue

  # Backoff: if same summary repeats, double the cooldown (up to MAX_COOLDOWN)
  if [[ "$reason" == "$LAST_SUMMARY" ]]; then
    REPEAT_COUNT=$((REPEAT_COUNT + 1))
    CURRENT_COOLDOWN=$((COOLDOWN * (1 << REPEAT_COUNT)))
    [[ $CURRENT_COOLDOWN -gt $MAX_COOLDOWN ]] && CURRENT_COOLDOWN=$MAX_COOLDOWN
  else
    REPEAT_COUNT=0
    CURRENT_COOLDOWN=$COOLDOWN
  fi
  LAST_SUMMARY="$reason"

  # Kick all idle managers
  kicked=0
  for mwin in $manager_wins; do
    # Only kick if manager is idle (screen check)
    "$BIN/agent-idle" "$mwin" 2>/dev/null || continue
    "$BIN/agent-kick" "$mwin" >/dev/null 2>&1
    kicked=$((kicked + 1))
  done
  if [[ $kicked -gt 0 ]]; then
    LAST_KICK=$now_epoch
    log "kicked $kicked manager(s) (wins: $manager_wins, next in ${CURRENT_COOLDOWN}s): $reason"
  fi
done
